{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media-router.dev/schemas/generation-result.schema.json",
  "title": "GenerationResult",
  "type": "object",
  "required": ["id", "jobId", "type", "provider", "providerId", "model", "status", "assets"],
  "properties": {
    "id": { "type": "string" },
    "jobId": { "type": "string" },
    "type": { "enum": ["image", "video", "audio", "model3d", "file"] },
    "provider": { "type": "string" },
    "providerId": { "type": "string" },
    "model": { "type": "string" },
    "status": { "const": "succeeded" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["image", "video", "audio", "model3d", "file"] },
          "url": { "type": "string" },
          "base64": { "type": "string" },
          "mimeType": { "type": "string" },
          "width": { "type": "number" },
          "height": { "type": "number" },
          "duration": { "type": "number" },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    },
    "usage": { "type": "object" },
    "timings": {
      "type": "object",
      "properties": {
        "createdAt": { "type": "string" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "media-router-error.schema.json" }
    },
    "children": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "jobId": { "type": "string" },
          "providerJobId": { "type": "string" },
          "status": {
            "enum": ["queued", "running", "succeeded", "failed", "cancelled"]
          },
          "error": { "$ref": "media-router-error.schema.json" }
        },
        "additionalProperties": true
      }
    },
    "raw": true,
    "resolved": { "type": "object" }
  },
  "additionalProperties": true
}
